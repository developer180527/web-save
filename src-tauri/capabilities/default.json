{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and quick-access windows",
  "windows": ["main", "quick"],
  "permissions": [
    "core:default",
    "opener:default",
    "log:default",
    "autostart:default",
    "dialog:default",
    "clipboard-manager:allow-read-text",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close"
  ]
}
